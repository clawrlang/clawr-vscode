{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Clawr",
  "scopeName": "source.clawr",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#regex" },
    { "include": "#numbers" },
    { "include": "#imports" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.clawr",
          "match": "//.*$"
        },
        {
          "name": "comment.block.clawr",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.clawr",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.clawr",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "regex": {
      "patterns": [
        {
          "name": "string.regexp.clawr",
          "begin": "(^|[=(:,\\[{!&|?;+\\-*%])\\s*(/)(?![/*\\s])",
          "beginCaptures": {
            "2": {
              "name": "punctuation.definition.string.begin.clawr"
            }
          },
          "end": "/[gmi]*",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.clawr"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.clawr",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.regexp.clawr",
          "begin": "\\b(?:return|if|while|case|in|and|or|throw|throws)\\b\\s+(/)(?![/*\\s])",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.string.begin.clawr"
            }
          },
          "end": "/[gmi]*",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.clawr"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.clawr",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.clawr",
          "match": "\\b(?:\\d[\\d_]*(?:\\.\\d[\\d_]*)?|\\.\\d[\\d_]*)(?:[eE][+-]?\\d[\\d_]*)?\\b"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.clawr",
          "match": "\\b(import)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+\\b(as)\\b\\s+([A-Za-z_][A-Za-z0-9_]*))?\\s+\\b(from)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.import.clawr"
            },
            "2": {
              "name": "variable.other.readwrite.imported.clawr"
            },
            "3": {
              "name": "keyword.control.import.clawr"
            },
            "4": {
              "name": "variable.other.alias.clawr"
            },
            "5": {
              "name": "keyword.control.import.clawr"
            }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.function.clawr",
          "match": "\\b(func)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.clawr"
            },
            "2": {
              "name": "entity.name.function.clawr"
            }
          }
        },
        {
          "name": "meta.declaration.type.clawr",
          "match": "\\b(data|object|service|enum|union|role|trait)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.clawr"
            },
            "2": {
              "name": "entity.name.type.clawr"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.clawr",
          "match": "\\b(?:if|else|guard|switch|when|is|case|do|while|for|in|and|or|return|continue|break|throw|throws|try|catch)\\b"
        },
        {
          "name": "keyword.declaration.clawr",
          "match": "\\b(?:func|operator|data|object|service|enum|union|role|trait|import|from|as|inheritance)\\b"
        },
        {
          "name": "storage.modifier.clawr",
          "match": "\\b(?:const|mut|ref|helper|mutating|pure|atomic|concurrent)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.clawr",
          "match": "\\b(?:false|ambiguous|true)\\b"
        },
        {
          "name": "variable.language.clawr",
          "match": "\\b(?:self|super)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.clawr",
          "match": "\\b(?:integer|real|truthvalue|text)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function-call.clawr",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.clawr"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.clawr",
          "match": "(?:\\|>|\\[>|=>|->|\\.\\.\\.|\\.\\.<|\\.\\.|===|!==|==|!=|<=|>=|<<|>>|&&|\\|\\||\\?\\?|\\?\\.|[+\\-*/%&|~^!<>:=@])"
        }
      ]
    }
  }
}
